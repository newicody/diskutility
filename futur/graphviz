avance

digraph SauvetageExpert {
    rankdir=TB;
    compound=true;
    node [fontname="Courier New", shape=box, style=filled, fillcolor="#2D2D2D", fontcolor="#FFFFFF", color="#555555", fontsize=9];
    edge [fontname="Arial", fontsize=9, color="#AAAAAA"];

    // =======================================================================
    // LÉGENDE - DISTINCTION VISUELLE
    // =======================================================================
    subgraph cluster_legend {
        label = "LÉGENDE - INTERVENTION HUMAINE";
        color="#000000";
        
        LegendAuto [label="🔵 AUTOMATIQUE\nDétectable par la machine\nSMART, dmesg, lsblk, etc.", shape=box, fillcolor="#0056b3", fontcolor="white"];
        
        LegendManual [label="🟠 INTERVENTION HUMAINE REQUISE\nParamètres que la machine ne peut pas connaître\nBruits, odeurs, décisions stratégiques", shape=box, fillcolor="#FF8F00", fontcolor="black"];
        
        LegendMixed [label="🟢 MIXTE\nDétection auto + validation humaine", shape=box, fillcolor="#2E7D32", fontcolor="white"];
        
        LegendUrgent [label="🔴 ALERTE HUMAINE\nSituation critique nécessitant décision immédiate", shape=box, fillcolor="#D32F2F", fontcolor="white"];
        
        LegendDecision [label="⬜ DÉCISION HUMAINE\nPoint de choix où l'utilisateur doit décider", shape=diamond, fillcolor="white", fontcolor="black"];
        
        LegendConfirm [label="✅ CONFIRMATION REQUISE\nChaque action affiche d'abord:\n• Ce qui va être fait\n• Les risques\n• Les alternatives\n• Puis demande confirmation", shape=box, fillcolor="#4CAF50", fontcolor="black"];
    }

    // =======================================================================
    // MONITORING CONTINU - AVEC CONFIRMATIONS
    // =======================================================================
    subgraph cluster_monitoring {
        label = "🔴 SURVEILLANCE CONTINUE - TOUT AU LONG DU PROCESSUS";
        color="#FF0000";
        fontcolor="#FF0000";
        
        MonitorTemp [label="🌡️ MONITORING TEMPÉRATURE\n🔵 AUTO: sensors, smartctl\n🟠 HUMAIN: Vérifier ventilation physique\n🔴 ALERTE: >55°C HDD, >70°C SSD\n✅ CONFIRMATION: Pause automatique ou manuelle?", 
                    tooltip="⚠️ ACTION PRÉVUE: Surveiller température toutes les 5 secondes\n🔴 SI >55°C: Envoyer SIGSTOP au processus\n📋 RAPPORT: Température actuelle: XX°C, Seuil: 55°C\n✅ Confirmez-vous la mise en pause automatique? (oui/non)",
                    shape=note, fillcolor="#BF360C"];
        
        MonitorSpeed [label="⚡ MONITORING VITESSE\n🔵 AUTO: ddrescue --status-interval\n🟠 HUMAIN: Interpréter tendances\n🔴 ALERTE: <100KB/s pendant 5min\n✅ CONFIRMATION: Changer stratégie?",
                     tooltip="⚠️ ACTION PRÉVUE: Surveiller vitesse de lecture\n🔴 SI <100KB/s pendant 5min: Proposer reverse mode\n📋 RAPPORT: Vitesse actuelle: XX KB/s, Durée ralentissement: X min\n✅ Voulez-vous passer en mode reverse? (oui/non)"];
        
        MonitorErrors [label="⚠️ MONITORING ERREURS\n🔵 AUTO: dmesg, smartctl -l error\n🟠 HUMAIN: Changer câble, vérifier connexions\n🔴 ALERTE: CRC errors, UNC, DRDY\n✅ CONFIRMATION: Continuer ou changer hardware?",
                      tooltip="⚠️ ACTION PRÉVUE: Analyser les erreurs noyau\n🔴 SI CRC errors > 10: Proposer changement câble\n📋 RAPPORT: X erreurs CRC détectées, Y erreurs UNC\n✅ Voulez-vous changer le câble maintenant? (oui/non)"];
        
        MonitorSound [label="🔊 MONITORING SONORE\n🟠 HUMAIN UNIQUEMENT - Écouter attentivement\n🔴 ALERTE: Nouveaux clics, grincement\n✅ CONFIRMATION: STOP immédiat si grincement",
                      tooltip="⚠️ ACTION REQUISE: Écouter le disque\n🎤 [APPUYEZ SUR ESPACE pour confirmer que vous écoutez]\n🔴 Si vous entendez un grincement: RÉPONDEZ 'STOP'\n📋 RAPPORT: Bruit détecté: [clic/grincement/silence]",
                      fillcolor="#FF8F00", fontcolor="black"];
        
        MonitorOdor [label="👃 MONITORING OLFACTIF\n🟠 HUMAIN UNIQUEMENT - Sentir\n🔴 ALERTE: Odeur de brûlé, composant chaud\n✅ CONFIRMATION: STOP immédiat",
                     tooltip="⚠️ ACTION REQUISE: Sentir l'odeur\n👃 [APPUYEZ SUR ESPACE pour confirmer que vous sentez]\n🔴 Si odeur de brûlé: RÉPONDEZ 'STOP'\n📋 RAPPORT: Odeur détectée: [normale/brûlé]",
                     fillcolor="#FF8F00", fontcolor="black"];
        
        MonitorVibration [label="🖐️ MONITORING VIBRATIONS\n🟠 HUMAIN UNIQUEMENT - Toucher\n🔴 ALERTE: Vibrations anormales\n✅ CONFIRMATION: Stabiliser ou arrêter",
                          tooltip="⚠️ ACTION REQUISE: Toucher le disque\n✋ [APPUYEZ SUR ESPACE pour confirmer que vous touchez]\n🔴 Si vibrations excessives: RÉPONDEZ 'STOP'\n📋 RAPPORT: Vibrations: [normales/anormales]",
                          fillcolor="#FF8F00", fontcolor="black"];
        
        MonitorProgress [label="📊 MONITORING PROGRESSION\n🔵 AUTO: map.log, taille image\n🟢 MIXTE: Décider quand arrêter\n✅ CONFIRMATION: 95% suffit? Réessayer zones?",
                         tooltip="⚠️ ACTION PRÉVUE: Analyser la progression\n📊 PROGRESSION: XX% récupéré, YY% non récupéré\n🔴 SI <95% après 24h: Proposer arrêt\n✅ Voulez-vous continuer? (oui/non/ignorer zones)",
                         fillcolor="#2E7D32", fontcolor="white"];
        
        MonitorHealth [label="🏥 MONITORING SMART\n🔵 AUTO: smartctl -A\n🟠 HUMAIN: Interpréter tendances\n🔴 ALERTE: Reallocated en hausse\n✅ CONFIRMATION: Accélérer ou ralentir?",
                       tooltip="⚠️ ACTION PRÉVUE: Analyser attributs SMART\n📊 Reallocated sectors: X (+Y en 1h), Pending: Z\n🔴 SI augmentation rapide: Proposer accélération\n✅ Voulez-vous augmenter la priorité? (oui/non)",
                       fillcolor="#2E7D32", fontcolor="white"];
    }

    // Connecter le monitoring à TOUS les blocs principaux
    MonitorTemp -> Start [style=dotted, color="#FF0000", label="SURVEILLANCE PERMANENTE"];
    MonitorSpeed -> Start [style=dotted, color="#FF0000"];
    MonitorErrors -> Start [style=dotted, color="#FF0000"];
    MonitorSound -> Start [style=dotted, color="#FF0000"];
    MonitorOdor -> Start [style=dotted, color="#FF0000"];
    MonitorVibration -> Start [style=dotted, color="#FF0000"];
    MonitorProgress -> Start [style=dotted, color="#FF0000"];
    MonitorHealth -> Start [style=dotted, color="#FF0000"];

    // =======================================================================
    // PHASE 1 : DIAGNOSTIC - AVEC CONFIRMATIONS
    // =======================================================================
    Start [label="ÉTAPE 1 : DIAGNOSTIC\n🔵 AUTO: smartctl, dmesg, lsblk\n🟠 HUMAIN: Écouter, sentir, toucher\n🟢 MIXTE: Interpréter résultats\n✅ CONFIRMATION: Valider chaque test", 
           tooltip="⚠️ ACTION PRÉVUE: Lancer diagnostic complet\n📋 RAPPORT PRÉLIMINAIRE:\n• Disque: /dev/sdX\n• Modèle: [détecté]\n• SMART: [PASS/FAIL]\n• Partitions: [trouvées]\n✅ Confirmez-vous le lancement du diagnostic? (oui/non)",
           shape=ellipse, fillcolor="#2E7D32"];

    subgraph cluster_diag {
        label = "RÉSULTATS DIAGNOSTIC - CONFIRMATION REQUISE";
        color="#444444";
        
        DiagOK [label="CAS 1 : Disque sain\n🔵 SMART PASS\n🔵 Pas d'erreur dmesg\n🟠 Pas de bruit anormal\n🔵 Partitions visibles\n✅ CONFIRMATION: Valider et continuer", 
                tooltip="📋 RAPPORT DIAGNOSTIC:\n✓ SMART: PASS\n✓ dmesg: 0 erreurs\n✓ Partitions: trouvées\n🟠 Bruits: [à confirmer par l'utilisateur]\n✅ Le disque semble sain. Procéder au backup préventif? (oui/non)",
                fillcolor="#0056b3"];
        
        DiagBad [label="CAS 2 : Disque défaillant accessible\n⚠️ SMART FAIL\n⚠️ Erreurs I/O\n⚠️ Secteurs realloués\n🟠 Bruits éventuels\n✅ CONFIRMATION: URGENCE - Agir", 
                 tooltip="📋 RAPPORT DIAGNOSTIC:\n✗ SMART: FAIL\n✗ Erreurs I/O: X détectées\n✗ Secteurs realloués: Y\n⚠️ URGENCE: Le disque peut lâcher\n✅ Confirmez-vous le lancement de la récupération d'urgence? (oui/non)",
                 fillcolor="#FF6B6B"];
        
        DiagNoise [label="CAS 3 : Bruits anormaux\n🟠 HUMAIN: Clics, grincement, bip\n✅ CONFIRMATION: Décrire le bruit", 
                   tooltip="📋 RAPPORT SONORE:\n🎤 [Veuillez décrire ce que vous entendez]\nOptions:\n1. Clics réguliers\n2. Grincement métallique\n3. Bip électronique\n4. Silence moteur\n5. Clics puis arrêt\n✅ Sélectionnez le type de bruit (1-5):",
                   fillcolor="#FF8F00", fontcolor="black"];
        
        DiagDead [label="CAS 4 : Disque non détecté\n🔵 Absent de lsblk\n🟠 HUMAIN: Vérifier branchement\n✅ CONFIRMATION: Actions physiques", 
                  tooltip="📋 RAPPORT:\n✗ Disque non détecté\n✅ Actions à effectuer:\n1. Avez-vous changé le câble? (oui/non)\n2. Avez-vous testé un autre port? (oui/non)\n3. Avez-vous testé sur un autre PC? (oui/non)\n✅ Après ces actions, le disque est-il détecté? (oui/non)",
                  fillcolor="#2E7D32", fontcolor="white"];
        
        DiagZFS [label="CAS 5 : Pool ZFS détecté\n🔵 zpool import\n🟠 HUMAIN: Sauver chaque disque d'abord\n✅ CONFIRMATION: Principe compris?", 
                 tooltip="📋 RAPPORT:\n✓ Pool ZFS détecté: [nom]\n⚠️ RAPPEL: Ne JAMAIS travailler sur les disques originaux\n✅ Avez-vous bien compris qu'il faut d'abord sauver chaque disque avec ddrescue? (oui/non)",
                 fillcolor="#2E7D32", fontcolor="white"];
        
        DiagRAID [label="CAS 6 : RAID logiciel détecté\n🔵 mdadm/LVM détecté\n🟠 HUMAIN: Assembler avant récupération\n✅ CONFIRMATION: Procéder à l'assemblage?", 
                  tooltip="📋 RAPPORT:\n✓ RAID détecté: [type]\n📋 Membres trouvés: [disques]\n✅ Voulez-vous assembler le RAID maintenant? (oui/non)",
                  fillcolor="#2E7D32", fontcolor="white"];
    }

    Start -> DiagOK;
    Start -> DiagBad;
    Start -> DiagNoise;
    Start -> DiagDead;
    Start -> DiagZFS;
    Start -> DiagRAID;

    // =======================================================================
    // BOUCLES DE RÉTROACTION - AVEC CONFIRMATIONS
    // =======================================================================
    subgraph cluster_feedback {
        label = "🔄 BOUCLES DE RÉTROACTION - DÉCISIONS HUMAINES AVEC CONFIRMATION";
        color="#FFA000";
        
        FeedbackTemp [label="⬜ DÉCISION HUMAINE: Température > seuil\n📋 RAPPORT: Température actuelle: XX°C\nOptions:\n1. Laisser le script gérer (SIGSTOP auto)\n2. Intervenir manuellement (ventilateur)\n3. Arrêter pour la nuit\n✅ Confirmez votre choix (1-3):", 
                      shape=diamond, fillcolor="white", fontcolor="black"];
        
        FeedbackSpeed [label="⬜ DÉCISION HUMAINE: Vitesse trop lente\n📋 RAPPORT: Vitesse: XX KB/s depuis X min\nOptions:\n1. Lancer reverse mode (--reverse)\n2. Augmenter skip (--skip 10M)\n3. Continuer (accepter lenteur)\n✅ Confirmez votre choix (1-3):", 
                       shape=diamond, fillcolor="white", fontcolor="black"];
        
        FeedbackErrors [label="⬜ DÉCISION HUMAINE: Erreurs détectées\n📋 RAPPORT: CRC: X, UNC: Y\nOptions:\n1. Changer câble maintenant\n2. Continuer (risqué)\n3. Passer en mode --direct\n✅ Confirmez votre choix (1-3):", 
                        shape=diamond, fillcolor="white", fontcolor="black"];
        
        FeedbackSound [label="⬜ DÉCISION HUMAINE: Bruit suspect\n📋 RAPPORT SONORE: [description]\n⚠️ Si grincement: STOP IMMÉDIAT\nOptions:\n1. Continuer (clics modérés)\n2. STOP (grincement)\n✅ Confirmez votre choix (1-2):", 
                       shape=diamond, fillcolor="white", fontcolor="black"];
    }

    // Connecter les feedbacks aux blocs concernés
    FeedbackTemp -> C2_HDD_Ideal [style=bold, color="#FFA000"];
    FeedbackSpeed -> C2_HDD_Ideal [style=bold, color="#FFA000"];
    FeedbackErrors -> C2_HDD_Ideal [style=bold, color="#FFA000"];
    FeedbackSound -> C2_HDD_Ideal [style=bold, color="#FFA000"];

    // =======================================================================
    // CAS 1 : DISQUE SAIN - AVEC CONFIRMATION
    // =======================================================================
    subgraph cluster_cas1 {
        label = "CAS 1 : DISQUE SAIN";
        color="#2E7D32";
        
        C1_Confirm [label="✅ CONFIRMATION PRÉALABLE\n📋 ACTION PRÉVUE: Backup préventif avec ddrescue\n📊 DESTINATION: /backup/disk.img (XX Go libres)\n⚠️ RISQUES: Aucun, opération non-destructive\n⏱️ TEMPS ESTIMÉ: X heures\n✅ Lancer le backup préventif? (oui/non)", 
                    shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C1_Ideal [label="🔵 BACKUP PRÉVENTIF\n◉ ddrescue -f -v /dev/sdX /backup/disk.img /backup/map.log", 
                  tooltip="Opération en cours...",
                  fillcolor="#0056b3"];
        
        C1_End [label="DISQUE OPÉRATIONNEL\nPlanifier sauvegardes régulières"];
    }

    DiagOK -> C1_Confirm;
    C1_Confirm -> C1_Ideal [label="Si oui"];
    C1_Confirm -> DiagOK [label="Si non, revenir", style=dotted];
    C1_Ideal -> C1_End;

    // =======================================================================
    // CAS 2 : DISQUE DÉFAILLANT - CONFIRMATIONS MULTIPLES
    // =======================================================================
    subgraph cluster_cas2 {
        label = "CAS 2 : DISQUE DÉFAILLANT";
        color="#FF6B6B";
        
        C2_Urgent [label="🔴 ALERTE HUMAINE - URGENCE\n✅ CONFIRMATION: Action immédiate requise?\n📋 RAPPORT: Disque défaillant détecté\n⚠️ RISQUE: Perte définitive possible\n✅ Confirmez-vous le lancement de la récupération d'urgence? (oui/non)", 
                   fillcolor="#D32F2F"];
        
        C2_Storage [label="⬜ DÉCISION: Stockage disponible ?\n📋 ESPACE LIBRE: /backup: XX Go\n📋 TAILLE DISQUE: YY Go\nOptions:\n1. Assez d'espace → méthode standard\n2. Pas assez → streaming\n3. Pas assez → chunking\n✅ Choix (1-3):", 
                    shape=diamond, fillcolor="white", fontcolor="black"];
        
        C2_Storage_OK [label="Stockage suffisant", shape=note, fillcolor="#0056b3"];
        
        C2_Type [label="⬜ DÉCISION: Type de disque ?\n📋 DÉTECTION AUTO: rotational=?\nOptions:\n1. HDD mécanique\n2. SSD/NVMe\n3. Je ne sais pas (laisser auto-détecter)\n✅ Choix (1-3):", 
                 shape=diamond, fillcolor="white", fontcolor="black"];
        
        // HDD
        C2_HDD [label="HDD MÉCANIQUE", fillcolor="#0056b3"];
        C2_HDD_Confirm [label="✅ CONFIRMATION HDD\n📋 ACTION: ddrescue standard\n⚙️ PARAMÈTRES: -f -n -v --direct\n⚠️ SURVEILLANCE: Température, bruits\n⏱️ ESTIMATION: X heures\n✅ Lancer ddrescue? (oui/non)", 
                        shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C2_HDD_Ideal [label="🔵 DDRESCUE EN COURS\n◉ ddrescue -f -n -v /dev/sdX /backup/disk.img /backup/map.log", 
                      tooltip="Opération en cours...",
                      fillcolor="#0056b3"];
        
        // SSD
        C2_SSD [label="SSD/NVMe", fillcolor="#0056b3"];
        C2_SSD_Confirm [label="✅ CONFIRMATION SSD\n📋 ACTION: dd bypass cache\n⚙️ PARAMÈTRES: iflag=nocache,noatime\n⚠️ VÉRIFIER: freeze lock\n⏱️ ESTIMATION: X heures\n✅ Lancer la lecture SSD? (oui/non)", 
                        shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C2_SSD_Ideal [label="🔵 LECTURE SSD EN COURS\n◉ dd if=/dev/sdX of=/backup/disk.img bs=1M iflag=nocache,noatime conv=noerror", 
                      tooltip="Opération en cours...",
                      fillcolor="#0056b3"];
        
        // Options stockage insuffisant
        C2_Storage_KO [label="Stockage insuffisant", shape=note, fillcolor="#FF8F00", fontcolor="black"];
        
        C2_Streaming [label="⬜ STREAMING CLOUD\n📋 DESTINATION: user@remote\n📋 DÉBIT NÉCESSAIRE: >10Mb/s\n⚠️ RISQUE: Coupure réseau\nOptions:\n1. Configurer streaming SSH\n2. Configurer rclone\n3. Annuler\n✅ Choix (1-3):", 
                      shape=diamond, fillcolor="white", fontcolor="black"];
        
        C2_Chunking [label="⬜ CHUNKING MULTI-DISQUES\n📋 DISQUES DISPONIBLES:\n• /media/disk1: XX Go\n• /media/disk2: YY Go\n• /media/disk3: ZZ Go\nOptions:\n1. Utiliser tous les disques\n2. Sélectionner disques\n3. Annuler\n✅ Choix (1-3):", 
                     shape=diamond, fillcolor="white", fontcolor="black"];
        
        C2_Crypto [label="⬜ DÉCISION: Disque chiffré ?\n📋 DÉTECTION AUTO: [LUKS/non]\nOptions:\n1. Oui (LUKS détecté)\n2. Non (pas de chiffrement)\n3. Je ne sais pas\n✅ Choix (1-3):", 
                   shape=diamond, fillcolor="white", fontcolor="black"];
        
        C2_Crypto_Yes [label="LUKS détecté", fillcolor="#FF8F00", fontcolor="black"];
        C2_Crypto_Confirm [label="✅ CONFIRMATION LUKS\n📋 ACTION: Sauver header d'abord\n🔐 FICHIER: header.luks\n⚠️ IMPORTANT: Sans header, données perdues\n✅ Sauvegarder le header LUKS? (oui/non)", 
                           shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C2_Crypto_Ideal [label="🟢 SAUVEGARDE HEADER\n◉ cryptsetup luksHeaderBackup /dev/sdX --header-backup-file header.luks", 
                         fillcolor="#2E7D32", fontcolor="white"];
        
        C2_Crypto_No [label="Non chiffré", fillcolor="#0056b3"];
    }

    DiagBad -> C2_Urgent;
    C2_Urgent -> C2_Storage [label="Si oui"];
    C2_Urgent -> DiagBad [label="Si non, revenir", style=dotted];
    
    C2_Storage -> C2_Storage_OK;
    C2_Storage -> C2_Storage_KO;
    
    C2_Storage_OK -> C2_Type;
    C2_Storage_KO -> C2_Streaming;
    C2_Storage_KO -> C2_Chunking;
    
    C2_Type -> C2_HDD;
    C2_Type -> C2_SSD;
    
    C2_HDD -> C2_Crypto;
    C2_SSD -> C2_Crypto;
    
    C2_Crypto -> C2_Crypto_Yes;
    C2_Crypto -> C2_Crypto_No;
    
    C2_Crypto_Yes -> C2_Crypto_Confirm;
    C2_Crypto_Confirm -> C2_Crypto_Ideal [label="Si oui"];
    C2_Crypto_Confirm -> C2_Crypto [label="Si non, revenir", style=dotted];
    
    C2_Crypto_Ideal -> C2_Crypto_No [label="Après sauvegarde header"];
    
    C2_Crypto_No -> C2_HDD_Confirm;
    C2_Crypto_No -> C2_SSD_Confirm;
    
    C2_HDD_Confirm -> C2_HDD_Ideal [label="Si oui"];
    C2_HDD_Confirm -> C2_HDD [label="Si non, revenir", style=dotted];
    
    C2_SSD_Confirm -> C2_SSD_Ideal [label="Si oui"];
    C2_SSD_Confirm -> C2_SSD [label="Si non, revenir", style=dotted];
    
    C2_Streaming -> C2_Type;
    C2_Chunking -> C2_Type;

    // =======================================================================
    // CAS 3 : BRUITS ANORMAUX - CONFIRMATIONS SONORES
    // =======================================================================
    subgraph cluster_cas3 {
        label = "CAS 3 : BRUITS ANORMAUX";
        color="#FF8F00";
        
        C3_Listen [label="🟠 ÉCOUTEZ LE DISQUE\n🎤 [APPUYEZ SUR ESPACE quand vous écoutez]\n📋 Une fois le bruit identifié, répondez:\n1. Clics réguliers\n2. Grincement métallique\n3. Bip électronique\n4. Silence moteur\n5. Clics puis arrêt", 
                   tooltip="En attente de votre réponse...",
                   shape=note, fillcolor="#FF8F00", fontcolor="black"];
        
        C3_Click [label="CLICS RÉGULIERS"];
        C3_Click_Confirm [label="✅ CONFIRMATION: Clics réguliers\n📋 ACTION PRÉVUE: ddrescue urgent\n⚠️ SURVEILLANCE: Écouter si bruit change\n⏱️ ESTIMATION: X heures\n✅ Lancer ddrescue? (oui/non)", 
                          shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C3_Click_Ideal [label="🔵 DDRESCUE URGENT", fillcolor="#0056b3"];
        
        C3_Scratch [label="GRINCEMENT MÉTALLIQUE"];
        C3_Scratch_Confirm [label="🔴 ALERTE: Grincement détecté\n⚠️ ACTION REQUISE: STOP IMMÉDIAT\n📋 COUPER L'ALIMENTATION MAINTENANT\n✅ Confirmez-vous que l'alimentation est coupée? (oui)", 
                            shape=note, fillcolor="#D32F2F", fontcolor="white"];
        
        C3_Scratch_Ideal [label="🟠 PASSER EN MODE PRO", fillcolor="#FF8F00", fontcolor="black"];
        
        C3_Beep [label="BIP ÉLECTRONIQUE"];
        C3_Beep_Confirm [label="✅ CONFIRMATION: Bip électronique\n📋 ACTION PRÉVUE: Changement PCB\n🔍 RECHERCHE: PCB identique (même firmware)\n⚠️ TRANSFERT: ROM à conserver\n✅ Procéder à la recherche de PCB? (oui/non)", 
                         shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C3_Beep_Ideal [label="🟠 RECHERCHE PCB", fillcolor="#FF8F00", fontcolor="black"];
        
        C3_Silent [label="SILENCE MOTEUR"];
        C3_Silent_Confirm [label="✅ CONFIRMATION: Silence moteur\n📋 ACTION PRÉVUE: Vérifier alimentation\n🔌 VÉRIFIER: Câble, alimentation, connecteurs\n✅ Avez-vous vérifié l'alimentation? (oui/non)", 
                           shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C3_Silent_Ideal [label="🟠 VÉRIFICATION ALIMENTATION", fillcolor="#FF8F00", fontcolor="black"];
        
        C3_ClickStop [label="CLICS PUIS ARRÊT"];
        C3_ClickStop_Confirm [label="✅ CONFIRMATION: Clics puis arrêt\n📋 ACTION PRÉVUE: Alimentation dédiée\n🔌 UTILISER: Alimentation secteur 12V+5V\n✅ Avez-vous branché une alimentation dédiée? (oui/non)", 
                              shape=note, fillcolor="#4CAF50", fontcolor="black"];
        
        C3_ClickStop_Ideal [label="🟠 ALIMENTATION DÉDIÉE", fillcolor="#FF8F00", fontcolor="black"];
    }

    DiagNoise -> C3_Listen;
    C3_Listen -> C3_Click;
    C3_Listen -> C3_Scratch;
    C3_Listen -> C3_Beep;
    C3_Listen -> C3_Silent;
    C3_Listen -> C3_ClickStop;
    
    C3_Click -> C3_Click_Confirm;
    C3_Click_Confirm -> C3_Click_Ideal [label="Si oui"];
    C3_Click_Confirm -> C3_Listen [label="Si non, revenir", style=dotted];
    C3_Click_Ideal -> C2_HDD_Ideal;
    
